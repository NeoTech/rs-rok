    "test": "bun test",
    "test:watch": "bun test --watch",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@cloudflare/vitest-pool-workers": "^0.13.5",
    "nanoid": "^5.0.9",
    "vitest": "^4.1.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241230.0",
    "typescript": "^5.7.0",
    "wrangler": "^3.114.17"
  }
}
